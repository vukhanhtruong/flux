# === Required ===
LOG_LEVEL=DEBUG

# === AI Provider (at least one required for agent bot) ===
# can pass either oauth or api here
CLAUDE_AUTH_TOKEN=sk-ant-oat01-xxx
# CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MODEL=claude-haiku-4-5-20251001

# === Messaging Platforms ===
# To get a token: message @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=8xxxx:AAxxxx
# To get your user_id: message @raw_data_bot
TELEGRAM_ALLOW_FROM=6666xxx

# === Web UI ===
VITE_SHOW_PROMO_CARD=true

# --- Encryption (required for backup feature) ---
FLUX_SECRET_KEY=your-strong-secret-key-here

# === Agent Bot ===
MCP_CONFIG_PATH=packages/agent-bot/src/flux_bot/mcp-config.json

# === Optional ===
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# --- Backup Settings ---
BACKUP_LOCAL_DIR=/tmp/backups

# Ngrok MCP Configuration
NGROK_AUTHTOKEN=your-token
NGROK_TUNNEL_PORT=5173
