# === AI Provider (required for agent bot) ===
CLAUDE_AUTH_TOKEN=sk-ant-...
CLAUDE_MODEL=haiku

# === Messaging Platforms ===
# To get a token: message @BotFather on Telegram -> /newbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# To get your user_id: message @raw_data_bot. Comma-separated for multi-user
TELEGRAM_ALLOW_FROM=111222333,444555666

# === Web UI ===
VITE_USER_ID=demo-user

