# === Required ===
POSTGRES_PASSWORD=changeme123

# === AI Provider (at least one required for agent bot) ===
CLAUDE_AUTH_TOKEN=sk-ant-...
CLAUDE_MODEL=haiku

# === Messaging Platforms ===
# To get a token: message @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# To get your user_id: message @raw_data_bot. Use comma-separated to allow multi user access your bot
TELEGRAM_ALLOW_FROM=111222333,444555666

# === Web UI ===
VITE_USER_ID=demo-user
VITE_SHOW_PROMO_CARD=true
# Set this to your messaging user_id after connecting (e.g., tg:123456)

# === Optional ===
# POSTGRES_USER=flux
# POSTGRES_DB=flux
# POSTGRES_PORT=5432
# API_PORT=8000
# WEB_PORT=5173
# EMBEDDING_MODEL=all-minilm:l6-v2
