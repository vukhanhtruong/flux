# === AI Provider (required for agent bot) ===
CLAUDE_AUTH_TOKEN=sk-ant-...
CLAUDE_MODEL=haiku

# === Messaging Platforms ===
# To get a token: message @BotFather on Telegram -> /newbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# To get your user_id: message @raw_data_bot. Comma-separated for multi-user
TELEGRAM_ALLOW_FROM=111222333,444555666

# === Web UI ===
VITE_USER_ID=demo-user

# === Logging ===
LOG_LEVEL=INFO # DEBUG | INFO | WARNING
# Per-layer overrides (uncomment as needed):
# LOG_LEVEL_SQL=DEBUG
# LOG_LEVEL_ZVEC=DEBUG
# LOG_LEVEL_UOW=DEBUG
# LOG_LEVEL_EVENTS=DEBUG
# LOG_LEVEL_BOT=DEBUG

# --- Encryption (required for backup feature) ---
FLUX_SECRET_KEY=your-strong-secret-key-here

# --- Backup Settings ---
BACKUP_LOCAL_DIR=/data/backups
BACKUP_LOCAL_RETENTION=7
BACKUP_S3_RETENTION=30
# S3 credentials are stored encrypted in SQLite, configurable via Web UI Settings.

# === Optional ===
# PORT=80
# DATABASE_PATH=/data/sqlite/flux.db
# ZVEC_PATH=/data/zvec
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# CORS_ORIGINS=http://localhost
# NGROK_AUTHTOKEN=your-token
# NGROK_TUNNEL_PORT=80
